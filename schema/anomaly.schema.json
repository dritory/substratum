{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/dritory/substratum/schema/anomaly.schema.json",
  "title": "Physics Anomaly / Tension Entry",
  "type": "object",
  "required": [
    "id",
    "name",
    "domain",
    "observable",
    "standard_prediction",
    "measurements",
    "tension_history",
    "status",
    "references"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$",
      "description": "Stable slug used as the filename."
    },
    "name": { "type": "string" },
    "aliases": {
      "type": "array",
      "items": { "type": "string" }
    },
    "domain": {
      "type": "string",
      "enum": [
        "particle",
        "cosmology",
        "gravitation",
        "condensed_matter",
        "nuclear",
        "atomic",
        "astrophysics",
        "theoretical"
      ]
    },
    "observable": {
      "type": "object",
      "required": ["symbol", "description"],
      "properties": {
        "symbol": { "type": "string" },
        "description": { "type": "string" },
        "units": { "type": "string" }
      }
    },
    "characteristic_scale": {
      "type": "object",
      "description": "Approximate scale where the observable is probed. Heuristic only; many observables do not have a single scale.",
      "properties": {
        "length_m": { "type": ["number", "null"] },
        "energy_ev": { "type": ["number", "null"] },
        "note": { "type": "string" }
      }
    },
    "standard_prediction": {
      "type": "object",
      "required": ["model", "value", "references"],
      "properties": {
        "model": {
          "type": "string",
          "description": "Which theoretical framework produces this prediction (e.g. 'Standard Model', 'LambdaCDM', 'QED + lattice HVP')."
        },
        "value": { "type": ["number", "string"] },
        "uncertainty": { "type": ["number", "string", "null"] },
        "units": { "type": "string" },
        "method_variants": {
          "type": "array",
          "description": "Alternative SM/baseline predictions when the theory side is itself contested (e.g. data-driven HVP vs lattice HVP for muon g-2).",
          "items": {
            "type": "object",
            "required": ["label", "value"],
            "properties": {
              "label": { "type": "string" },
              "value": { "type": ["number", "string"] },
              "uncertainty": { "type": ["number", "string", "null"] },
              "reference": { "type": "string" },
              "note": { "type": "string" }
            }
          }
        },
        "references": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "measurements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["experiment", "value", "year", "reference"],
        "properties": {
          "experiment": { "type": "string" },
          "value": { "type": ["number", "string"] },
          "uncertainty": { "type": ["number", "string", "null"] },
          "units": { "type": "string" },
          "year": { "type": "integer" },
          "reference": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    },
    "tension_history": {
      "type": "array",
      "description": "How the discrepancy's significance has evolved over time. Each entry is a snapshot.",
      "items": {
        "type": "object",
        "required": ["year", "sigma", "note"],
        "properties": {
          "year": { "type": "integer" },
          "sigma": { "type": ["number", "string"] },
          "comparison": {
            "type": "string",
            "description": "What was being compared (e.g. 'BNL+FNAL avg vs WP2020 SM data-driven HVP')."
          },
          "note": { "type": "string" }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["open", "contested", "resolved", "theoretical", "watching"]
    },
    "trend": {
      "type": "string",
      "enum": ["growing", "stable", "shrinking", "resolved", "theoretical"],
      "description": "Direction of the discrepancy's significance over recent years. Orthogonal to status; an entry can be 'open' and 'stable' or 'contested' and 'shrinking'."
    },
    "principles_stressed": {
      "type": "array",
      "description": "Foundational principles that this anomaly would stress IF it is fundamentally real and not a systematic. The default and most common entry is the explicit 'none' record: documenting that an anomaly does not break a foundational principle is just as informative as documenting one that does.",
      "items": {
        "type": "object",
        "required": ["principle", "status"],
        "properties": {
          "principle": {
            "type": "string",
            "enum": [
              "unitarity",
              "causality",
              "lorentz_invariance",
              "cpt",
              "equivalence_principle",
              "lepton_flavor_universality",
              "gauge_invariance",
              "locality",
              "background_independence",
              "naturalness",
              "none"
            ]
          },
          "status": {
            "type": "string",
            "enum": ["would_violate", "stresses", "tests", "none", "contested"]
          },
          "note": { "type": "string" }
        }
      }
    },
    "smeft_context": {
      "type": "object",
      "description": "How this anomaly enters the Standard Model Effective Field Theory (Warsaw basis). Particle-physics entries only; cosmology/astrophysics entries should leave this field unset.",
      "properties": {
        "operators": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "description"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Warsaw-basis operator label, e.g. 'O_eB', 'O_eW', 'O_HD', 'O_HWB'."
              },
              "dimension": { "type": "integer" },
              "description": { "type": "string" },
              "current_bound": {
                "type": "string",
                "description": "Symbolic statement of the current Wilson-coefficient bound, e.g. '|C_eγ^μμ| / Λ² < few × 10^-9 GeV^-2'."
              },
              "reference": { "type": "string" }
            }
          }
        },
        "oblique_parameters": {
          "type": "object",
          "description": "Peskin-Takeuchi S/T/U where directly relevant.",
          "properties": {
            "S": { "type": "string" },
            "T": { "type": "string" },
            "U": { "type": "string" },
            "reference": { "type": "string" }
          }
        },
        "global_fits": {
          "type": "array",
          "description": "References to standard SMEFT global fits whose constraints this entry should be checked against.",
          "items": { "type": "string" }
        }
      }
    },
    "cosmology_context": {
      "type": "object",
      "description": "Extension classes that move the needle on this tension, and what each costs elsewhere. Cosmology/astrophysics entries only. Prefer mechanism_links at the top level for new entries; extension_classes is retained for entries whose extensions are not (yet) lifted into mechanisms/.",
      "properties": {
        "extension_classes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "effect"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Extension class name (e.g. 'Early Dark Energy', 'Interacting Dark Sector', 'Sign-switching Lambda')."
              },
              "effect": {
                "type": "string",
                "description": "How and how much it moves this tension."
              },
              "cost_elsewhere": {
                "type": "string",
                "description": "What other tension or constraint is exacerbated."
              },
              "reference": { "type": "string" }
            }
          }
        }
      }
    },
    "mechanism_links": {
      "type": "array",
      "description": "List of mechanisms/<id> entries that propose to address this tension/puzzle. Cross-checked by the validator.",
      "items": { "type": "string" }
    },
    "puzzle_links": {
      "type": "array",
      "description": "List of puzzles/<id> entries that this data entry exemplifies. Cross-checked by the validator.",
      "items": { "type": "string" }
    },
    "summary": {
      "type": "string",
      "description": "Plain-English summary, 2-4 sentences."
    },
    "systematics_notes": {
      "type": "string",
      "description": "Known systematic concerns or theoretical disputes that affect interpretation."
    },
    "references": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["citation"],
        "properties": {
          "citation": { "type": "string" },
          "doi": { "type": "string" },
          "arxiv": { "type": "string" },
          "url": { "type": "string" }
        }
      }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
